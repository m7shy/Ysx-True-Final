# --- GMAIL CONFIGURATION ---
GMAIL_USER=youssef.ysx@youssefahmed.design
GMAIL_APP_PASSWORD=ygfj dqaa wxyt uzls

# --- ZOHO CONFIGURATION ---
ZOHO_USER=
ZOHO_APP_PASSWORD=

# --- MICROSOFT / OUTLOOK CONFIGURATION ---
MICROSOFT_USER=YoussefAhmed@outreach.ysxvisuals.com

# SMTP (Basic Auth) - keep if you rely on SMTP via smtp.office365.com
MICROSOFT_APP_PASSWORD=hydhszlgywcwlmch

# IMAP (OAuth2 / XOAUTH2) - required to permanently fix Outlook IMAP (Basic/App Password is blocked in many tenants)
# Create an Azure App Registration and enable Device Code Flow (public client flows).
MICROSOFT_CLIENT_ID=7f03ed98-5a4c-43d4-b2ee-de16ab442a36
MICROSOFT_CLIENT_SECRET=nXL8Q~L_4c2u7audD3Sa7c8CUZKYf-DEAJNqJcYU
# Optional (recommended for enterprise): Tenant ID (GUID). If omitted, uses "common".
MICROSOFT_TENANT_ID=7d9dc0cf-0600-4f46-bc9d-b74602c1661f
# Optional: Override authority base URL (advanced). Examples:
# - https://login.microsoftonline.com
# - https://login.microsoftonline.com/{tenant}
MICROSOFT_OAUTH_AUTHORITY=https://login.microsoftonline.com
# Optional: Where to store refresh tokens (server-side only). Default: server/data/tokens.json
TOKEN_STORAGE_PATH=data/tokens.json

# IMAP server (defaults to outlook.office365.com:993)
MICROSOFT_IMAP_HOST=outlook.office365.com
MICROSOFT_IMAP_PORT=993

# SMTP server (defaults based on account type; typically smtp.office365.com:587 for M365)
MICROSOFT_SMTP_HOST=smtp.office365.com
MICROSOFT_SMTP_PORT=587

# --- EXTRA (present in your existing .env, not in .env.example) ---
WEB_ORIGIN=http://localhost:3000
